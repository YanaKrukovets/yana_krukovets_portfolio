# Copy to .env.local and fill in. .env*.local is gitignored.

# Gemini AI — powers the chat widget (pages/api/chat.js) and the analytics
# improvement suggestions (pages/api/insights.js).
GEMINI_API_KEY=

# Supabase — backend store for the custom analytics. Use the SERVICE ROLE key
# (Project Settings -> API). It is server-only and must never be exposed to the
# browser. See supabase/schema.sql for the table definition.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics dashboard (pages/admin/analytics.js) auth.
# ANALYTICS_ADMIN_PASSWORD: the password you type to sign in.
# ANALYTICS_SESSION_SECRET: a long random string used to sign the session cookie
#   (generate e.g. with: openssl rand -hex 32).
ANALYTICS_ADMIN_PASSWORD=
ANALYTICS_SESSION_SECRET=
